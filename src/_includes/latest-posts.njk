<section>
  <h2>Latest posts</h2>
  <div class="grid">
    {%- for post in collections.posts | reverse -%}
      {%- if loop.index0 < 3 -%}
        <div>
          <article>
            <header>
              <small><code>{{ post.date | dateFormat }}</code></small>
            </header>
            <hgroup>
              <span class="blog-post-list-heading"><a href="{{ post.url }}">{{ post.data.title }}</a></span>
              <p>{{ post.data.description }}</p>
            </hgroup>
          </article>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="homepage-button">
    <a href="/blog/" role="button" class="outline">View all posts</a>
  </div>
</section>
