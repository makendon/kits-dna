{
  "name": "kits-dna",
  "version": "3.0.0",
  "description": "`kits-dna` is the repository name for **kitfrance.com**. Built with Eleventy.",
  "main": "index.js",
  "scripts": {
    "update": "npx npm-check-updates -u",
    "markdown": "markdownlint-cli2 '**/*.md' '!node_modules' '!LICENSE.md'",
    "markdown:fix": "markdownlint-cli2 --fix '**/*.md' '!node_modules' '!LICENSE.md'",
    "spell": "npx cspell-cli '**/*.md' '!node_modules' '!LICENSE.md'",
    "vale": "vale --glob=!LICENSE.md .",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "links": "lychee --base-url 'http://localhost:8080' 'dist/**/*.html'",
    "test": "npx playwright test",
    "test:report": "npx playwright show-report",
    "test:ui": "npx playwright test --ui",
    "clean": "rm -rf dist && rm -rf .cache && rm -rf playwright-report && rm -rf test-results",
    "watch:sass": "sass --load-path=node_modules/@picocss/pico/scss/ --watch src/_sass/styles.scss:dist/css/styles.css",
    "build:sass": "sass --load-path=node_modules/@picocss/pico/scss/ src/_sass/styles.scss dist/css/styles.css",
    "watch:eleventy": "npx @11ty/eleventy --serve",
    "build:eleventy": "npx eleventy",
    "build:search": "npx pagefind --site dist",
    "start": "ELEVENTY_ENVIRONMENT=development npm-run-all build:sass --parallel watch:*",
    "build": "ELEVENTY_ENVIRONMENT=production npm-run-all build:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makendon/kits-dna.git"
  },
  "keywords": [],
  "author": "Kit France",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/makendon/kits-dna/issues"
  },
  "homepage": "https://kitfrance.com",
  "type": "module",
  "dependencies": {
    "@picocss/pico": "2.1.1"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.2",
    "@11ty/eleventy-fetch": "5.1.1",
    "@11ty/eleventy-img": "6.0.4",
    "@11ty/eleventy-navigation": "1.0.5",
    "@11ty/eleventy-plugin-rss": "2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "5.0.2",
    "@11ty/font-awesome": "1.0.1",
    "@axe-core/playwright": "4.11.1",
    "@eslint/js": "10.0.1",
    "@netlify/plugin-csp-nonce": "1.6.2",
    "@playwright/test": "1.58.2",
    "@types/node": "25.3.3",
    "cspell-cli": "9.7.0",
    "eslint": "10.0.2",
    "globals": "17.4.0",
    "markdown-it": "14.1.1",
    "markdown-it-anchor": "9.2.0",
    "markdown-it-emoji": "3.0.0",
    "markdown-it-github-alerts": "1.0.1",
    "markdownlint-cli2": "0.21.0",
    "netlify-plugin-cache": "1.0.3",
    "npm-run-all": "4.1.5",
    "pagefind": "1.4.0",
    "prismjs": "1.30.0",
    "sass": "1.97.3"
  }
}
